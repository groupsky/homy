# Test environment configuration for CI healthcheck tests
# DO NOT use these values in production - for testing only

# Test mode - allows service to start even if external connections fail
TEST_MODE=true

# MQTT Configuration (required)
MQTT_PASSWORD=test-password-ci-only
MQTT_DEVICE_ID=test-device-ci-123456789
MQTT_APP_ID=test-app-ci-987654321

# Optional MQTT settings (defaults available in constants.js)
# MQTT_URL=mqtt://mqtts.sk-robot.com:1883
# MQTT_USERNAME=app

# InfluxDB Configuration (required - using token auth)
INFLUXDB_TOKEN=test-token-ci-only

# Optional InfluxDB settings (defaults available in constants.js)
# INFLUXDB_URL=http://influxdb:8086
# INFLUXDB_ORG=
# INFLUXDB_BUCKET=sunseeker
